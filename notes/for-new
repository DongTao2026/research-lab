<button id="scrollTop" onclick="window.scrollTo({top:0,behavior:'smooth'})">↑</button>

<script>
  // Expand/collapse cards
  function toggleExpand(card) {
    const expand = card.querySelector('.card-expand');
    if (expand) expand.classList.toggle('open');
  }

  // Checkbox toggle
  function toggleCheck(box) {
    box.classList.toggle('checked');
    const text = box.nextElementSibling;
    if (text) text.classList.toggle('done');
    saveProgress();
  }

  // Scroll progress
  const progressBar = document.getElementById('progress-bar');
  const scrollTopBtn = document.getElementById('scrollTop');
  const main = document.getElementById('main');

  window.addEventListener('scroll', () => {
    const scrolled = window.scrollY;
    const total = document.documentElement.scrollHeight - window.innerHeight;
    progressBar.style.transform = `scaleX(${scrolled / total})`;
    scrollTopBtn.classList.toggle('visible', scrolled > 300);

    // Highlight nav
    document.querySelectorAll('section[id]').forEach(sec => {
      const top = sec.getBoundingClientRect().top;
      if (top < 100 && top > -sec.offsetHeight + 100) {
        document.querySelectorAll('.nav-list a').forEach(a => a.classList.remove('active'));
        const link = document.querySelector(`.nav-list a[href="#${sec.id}"]`);
        if (link) link.classList.add('active');
      }
    });
  });

  // Smooth scroll
  document.querySelectorAll('a[href^="#"]').forEach(link => {
    link.addEventListener('click', e => {
      e.preventDefault();
      const target = document.querySelector(link.getAttribute('href'));
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  // Save/load progress
  function saveProgress() {
    const state = {};
    document.querySelectorAll('.check-box').forEach((box, i) => {
      state[i] = box.classList.contains('checked');
    });
    localStorage.setItem('investment-handbook-progress', JSON.stringify(state));
  }

  function loadProgress() {
    const saved = localStorage.getItem('investment-handbook-progress');
    if (!saved) return;
    const state = JSON.parse(saved);
    document.querySelectorAll('.check-box').forEach((box, i) => {
      if (state[i]) {
        box.classList.add('checked');
        const text = box.nextElementSibling;
        if (text) text.classList.add('done');
      }
    });
  }

  loadProgress();
</script>
